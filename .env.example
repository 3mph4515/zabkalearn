# Telegram bot (from @BotFather)
BOT_TOKEN=

# Editor password (gates web editor access from Telegram /editor command)
EDITOR_PASSWORD=

# Telegram API credentials (from https://my.telegram.org)
TG_API_ID=
TG_API_HASH=

# Scheduler web auth token (random string, e.g. `openssl rand -base64 32`)
SCHEDULER_TOKEN=

# Scheduler bind host/port
HOST=127.0.0.1
PORT=8080

# Deploy targets
VPS_HOST=my-vps
REMOTE_DIR=/opt/polski-daily-bot
